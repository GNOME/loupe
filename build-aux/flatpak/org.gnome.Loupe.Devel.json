{
    "id": "org.gnome.Loupe.Devel",
    "runtime": "org.gnome.Platform",
    "runtime-version": "master",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable",
        "org.freedesktop.Sdk.Extension.llvm21"
    ],
    "command": "loupe",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=host",
        "--env=RUST_BACKTRACE=1",
        "--env=RUST_LOG=debug",
        "--talk-name=org.gtk.vfs.*",
        "--filesystem=xdg-run/gvfs",
        "--filesystem=xdg-run/gvfsd"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin:/usr/lib/sdk/llvm21/bin",
        "build-args": [
            "--share=network"
        ],
        "env": {
            "RUSTFLAGS": "-C force-frame-pointers=yes",
            "CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_LINKER": "clang",
            "CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_LINKER": "clang",
            "CARGO_TARGET_X86_64_UNKNOWN_LINUX_GNU_RUSTFLAGS": "-C link-arg=-fuse-ld=/usr/lib/sdk/rust-stable/bin/mold",
            "CARGO_TARGET_AARCH64_UNKNOWN_LINUX_GNU_RUSTFLAGS": "-C link-arg=-fuse-ld=/usr/lib/sdk/rust-stable/bin/mold"
        }
    },
    "modules": [
        {
            "name": "geocode-glib",
            "buildsystem": "meson",
            "config-opts": [
                "-Denable-installed-tests=false",
                "-Denable-introspection=false",
                "-Denable-gtk-doc=false",
                "-Dsoup2=false"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/geocode-glib/3.26/geocode-glib-3.26.4.tar.xz",
                    "sha256": "2d9a6826d158470449a173871221596da0f83ebdcff98b90c7049089056a37aa",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "geocode-glib"
                    }
                }
            ]
        },
        {
            "name": "gweather-locations",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/gweather-locations/2026/gweather-locations-2026.2.tar.xz",
                    "sha256": "e7570a3661e0a752a06387b2032585cf588fc56770b1f9f39f1a55d17b2835fe",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "gweather-locations"
                    }
                }
            ]
        },
        {
            "name": "libgweather",
            "buildsystem": "meson",
            "config-opts": [
                "-Denable_vala=false",
                "-Dgtk_doc=false",
                "-Dintrospection=false",
                "-Dtests=false"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/libgweather/4.6/libgweather-4.6.0.tar.xz",
                    "sha256": "7f5d0e8c9685ef2ff46c2f3a57cae48d7bf3540b2d83921f889ef28e6a876788",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "libgweather",
                        "versions": {
                            "<": "40.alpha"
                        }
                    }
                }
            ]
        },
        {
            "name": "glycin-loaders",
            "buildsystem": "meson",
            "config-opts": [
                "-Dloaders=glycin-raw",
                "-Dlibglycin=false",
                "-Dlibglycin-gtk4=false",
                "-Dglycin-thumbnailer=false"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/GNOME/glycin.git",
                    "commit": "61f344b5f46c8755a01b1d99edb49074fa64da8a"
                }
            ]
        },
        {
            "name": "loupe",
            "buildsystem": "meson",
            "config-opts": [
                "-Dprofile=dev",
                "-Dapp_id_suffix=.Devel"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/GNOME/loupe.git"
                }
            ]
        }
    ]
}
